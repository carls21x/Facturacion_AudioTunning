<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".ForgottenPassword">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:padding="32dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="360dp" android:layout_height="220dp"
                android:layout_marginBottom="32dp"
                android:src="@drawable/logo" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp" app:cardElevation="0dp"
                app:strokeColor="@color/black"
                app:strokeWidth="4dp"> <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rf_dewi_condensed_black"
                android:paddingHorizontal="32dp"
                android:paddingVertical="16dp"
                android:textAlignment="center"
                android:text="¿OLVIDASTE TU\nCONTRASEÑA?"
                android:textColor="@color/black"
                android:textSize="28sp" android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp" android:fontFamily="@font/afacad_medium"
                android:text="No te preocupes, envía un correo con tu solicitud y tus datos generales para realizar el cambio de contraseña."
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="24sp" android:lineSpacingExtra="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCorreoCard"
                android:layout_width="match_parent"
                android:layout_height="80dp" android:layout_marginHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/red"
                app:cardCornerRadius="16dp" app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/rf_dewi_condensed_black"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="ENVIAR CORREO DE SOLICITUD"
                    android:textColor="@color/white"
                    android:textSize="24sp" android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnVolverLogin"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/afacad_medium"
                android:text="Volver al inicio"
                android:textSize="20sp" android:textColor="@color/black" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>